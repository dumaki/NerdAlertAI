    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "imapflow": "^1.3.3",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "keytar": "^7.9.0",
    "mailparser": "^3.9.8",
    "mammoth": "^1.7.0",
    "mathjs": "^15.2.0",
