# === SECRETS — NEVER COMMIT ===
# This is the most important entry in this file.
# The .env file contains your API keys and passwords.
# It must never appear in version control. Ever.
.env

# === BUILD OUTPUT ===
# The compiled JavaScript output — regenerated from source, not tracked
dist/

# === DEPENDENCIES ===
# npm install recreates this from package.json — no need to track it
node_modules/

# === LOGS ===
# Agent action logs — may contain sensitive info
logs/*.log

# === OS FILES ===
.DS_Store
Thumbs.db

#== CRON FILES ==
data/cron.db
data/cron.db-wal
data/cron.db-shm
data/last_shutdown.txt

#== REMINDERS FILES ==
data/reminders.db
data/reminders.db-wal
data/reminders.db-shm
.env*

# === VOICE MODELS ===
# Voice ONNX files are large binaries (50–100 MB) and live outside the
# repo at ~/.nerdalert/voices/. The voices.example/ folder only holds
# documentation, never actual voice files. This is a safety net in case
# something gets dropped in by accident.
*.onnx
*.onnx.json

# === GENERATED AUDIO ===
# TTS / STT testing leaves stray .wav files in the working directory
# (piper writes timestamped files when the output path isn't explicit).
# These are ephemeral test artifacts and license-encumbered, never
# belong in the repo. Blanket ignore for safety.
# .webm joins the list for STT testing — browser MediaRecorder output
# captured for offline replay should never get committed.
*.wav
*.mp3
*.ogg
*.flac
*.webm

# === WHISPER MODELS ===
# Whisper.cpp ggml-*.bin model files are large binaries (100-3000 MB)
# and live outside the repo at ~/.nerdalert/whisper-models/. The
# whisper-models.example/ folder only holds documentation, never
# actual model files. Blanket ignore as a safety net so a stray
# `cp` into the repo can't ship a multi-GB binary.
*.bin
